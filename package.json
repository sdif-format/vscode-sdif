{
  "name": "vscode-sdif",
  "displayName": "SDIF",
  "description": "VS Code language support for the Semantic Data Interchange Format.",
  "version": "1.0.0",
  "publisher": "sdif-format",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/sdif-format/vscode-sdif.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "sdif",
    "semantic-data",
    "lsp",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:sdif",
    "onCommand:sdif.restartServer",
    "onCommand:sdif.showOutput"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sdif",
        "aliases": [
          "SDIF",
          "sdif"
        ],
        "extensions": [
          ".sdif",
          ".sdif.ai",
          ".sdif.canon"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sdif",
        "scopeName": "source.sdif",
        "path": "./syntaxes/sdif.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "SDIF Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/sdif-dark-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "sdif.restartServer",
        "title": "SDIF: Restart Language Server"
      },
      {
        "command": "sdif.showOutput",
        "title": "SDIF: Show Output"
      }
    ],
    "configuration": {
      "title": "SDIF",
      "properties": {
        "sdif.server.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the SDIF language server client. Syntax highlighting remains available when disabled."
        },
        "sdif.server.path": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to an external sdif-lsp binary. If not specified, the extension will use the bundled binary or look for it in the workspace/PATH."
        },
        "sdif.server.command": {
          "type": "string",
          "default": "sdif-lsp",
          "description": "Fallback command name or system PATH command used to start the Rust SDIF language server when no path or bundled binary is found."
        },
        "sdif.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the SDIF language server command."
        },
        "sdif.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the SDIF language server."
        }
      }
    },
    "semanticTokenTypes": [
      { "id": "keyword",  "superType": "keyword",  "description": "SDIF directive names and structural keys." },
      { "id": "type",     "superType": "type",     "description": "Table names, narrative keys, block identifiers." },
      { "id": "property", "superType": "property", "description": "Table column headers and alias entries." },
      { "id": "variable", "superType": "variable", "description": "Table row identifiers and relation subjects." },
      { "id": "enum",     "superType": "enum",     "description": "Enumerated values: null, true, false and domain constants." },
      { "id": "string",   "superType": "string",   "description": "Quoted strings, unquoted scalars and narrative text." },
      { "id": "number",   "superType": "number",   "description": "Numeric literals." },
      { "id": "operator", "superType": "operator", "description": "Punctuation: @, \"\"\", brackets, delimiters." },
      { "id": "comment",  "superType": "comment",  "description": "Line comments starting with #." }
    ],
    "semanticTokenModifiers": [
      {
        "id": "sdifColumn0",
        "description": "SDIF table column 0."
      },
      {
        "id": "sdifColumn1",
        "description": "SDIF table column 1."
      },
      {
        "id": "sdifColumn2",
        "description": "SDIF table column 2."
      },
      {
        "id": "sdifColumn3",
        "description": "SDIF table column 3."
      },
      {
        "id": "sdifColumn4",
        "description": "SDIF table column 4."
      },
      {
        "id": "sdifColumn5",
        "description": "SDIF table column 5."
      },
      {
        "id": "sdifColumn6",
        "description": "SDIF table column 6."
      },
      {
        "id": "sdifColumn7",
        "description": "SDIF table column 7."
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "sdif",
        "scopes": {
          "*.sdifColumn0": [
            "variable.other.readwrite.sdif"
          ],
          "*.sdifColumn1": [
            "constant.other.sdif"
          ],
          "*.sdifColumn2": [
            "entity.name.type.sdif"
          ],
          "*.sdifColumn3": [
            "string.quoted.double.sdif"
          ],
          "*.sdifColumn4": [
            "support.constant.sdif"
          ],
          "*.sdifColumn5": [
            "constant.numeric.sdif"
          ],
          "*.sdifColumn6": [
            "entity.name.function.sdif"
          ],
          "*.sdifColumn7": [
            "variable.parameter.sdif"
          ]
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test:unit": "tsc -p tsconfig.test.json && node out-test/test/suite/manifest.test.js && node out-test/test/suite/config.test.js && node out-test/test/suite/activation.test.js && node out-test/test/suite/syntax.test.js && node out-test/test/suite/compatibility.test.js && node out-test/test/suite/package.test.js && node out-test/test/suite/package-release.test.js",
    "test": "npm run test:unit",
    "package:prepare": "node scripts/prepare-lsp-binaries.mjs",
    "prepackage": "npm run package:prepare",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.92.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.6.3"
  }
}
