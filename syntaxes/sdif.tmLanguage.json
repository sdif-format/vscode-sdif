{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SDIF Fallback",
  "scopeName": "source.sdif",
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#tripleQuotedNarrative" },
    { "include": "#quotedStrings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sdif",
          "match": "(^|\\s)#.*$"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.directive.sdif",
          "match": "^(@)([A-Za-z][A-Za-z0-9_.-]*)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.directive.sdif" },
            "2": { "name": "keyword.control.directive.sdif" }
          }
        }
      ]
    },
    "tripleQuotedNarrative": {
      "patterns": [
        {
          "name": "string.quoted.triple.sdif",
          "begin": "\\\"\\\"\\\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.sdif" }
          },
          "end": "\\\"\\\"\\\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.sdif" }
          }
        }
      ]
    },
    "quotedStrings": {
      "patterns": [
        {
          "name": "string.quoted.double.sdif",
          "match": "\\\"(?:[^\\\\\\\"]|\\\\.)*\\\""
        }
      ]
    }
  }
}
